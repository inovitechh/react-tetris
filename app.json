{
  "expo": {
    "name": "React Tetris",
    "slug": "react-tetris",
    "version": "1.0.0",
    "description": "Classic Tetris game with modern touch controls",
    "author": "Inovi Tech Corp",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2C2C2C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rmztngame.reacttetris",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rmztngame.reacttetris",
      "versionCode": 5,
      "versionName": "1.0.0",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2C2C2C"
      },
      "permissions": [],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.rmztngame.reacttetris"
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "1ad863ca-dd41-4c79-b074-a8aceab6538e"
      }
    }
  }
}
